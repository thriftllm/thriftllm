# ============================================
# ThriftLLM Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- Core ----
THRIFT_ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string
THRIFT_JWT_SECRET=change-me-to-a-strong-random-secret    # REQUIRED: use `openssl rand -hex 32`
THRIFT_CACHE_THRESHOLD=0.95

# ---- Security (Production) ----
# Set to "true" when serving over HTTPS
THRIFT_SECURE_COOKIES=false
# Comma-separated allowed origins (leave empty for localhost defaults)
# Example: https://dashboard.example.com,https://api.example.com
THRIFT_CORS_ORIGINS=

# ---- Database ----
POSTGRES_DB=thriftllm
POSTGRES_USER=thrift
POSTGRES_PASSWORD=thriftllm_secret_password
DATABASE_URL=postgres://thrift:thriftllm_secret_password@postgres:5432/thriftllm?sslmode=disable

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- Frontend ----
BACKEND_URL=http://backend:8080

# ============================================
# Provider API Keys
# Add the keys for providers you want to use
# ============================================

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AI...

# Groq (OpenAI-compatible)
GROQ_API_KEY=gsk_...

# Together AI (OpenAI-compatible)
TOGETHER_API_KEY=...

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=...

# Custom / Self-hosted (OpenAI-compatible)
# CUSTOM_API_KEY=...
# CUSTOM_API_BASE=http://localhost:11434/v1
